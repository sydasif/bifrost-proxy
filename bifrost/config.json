{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "enable_logging": true,
    "compat": {
      "should_drop_params": true,
      "should_convert_params": true
    }
  },
  "providers": {
    "opencode": {
      "keys": [
        {
          "name": "opencode-key",
          "value": "env.OPENCODE_API_KEY",
          "models": ["nemotron-3-ultra-free", "deepseek-v4-flash-free"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://opencode.ai/zen",
        "default_request_timeout_in_seconds": 180,
        "max_retries": 2
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        }
      }
    },
    "agnes": {
      "keys": [
        {
          "name": "agnes-key",
          "value": "env.AGNES_API_KEY",
          "models": ["agnes-2.0-flash"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://apihub.agnes-ai.com",
        "default_request_timeout_in_seconds": 180,
        "max_retries": 2
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true,
          "responses": false,
          "responses_stream": false
        }
      }
    }
  },
  "vector_store": {
    "enabled": true,
    "type": "redis",
    "config": {
      "addr": "redis:6379"
    }
  },
  "plugins": [
    {
      "enabled": true,
      "name": "semantic_cache",
      "config": {
        "dimension": 1,
        "ttl": "10m",
        "cache_by_model": true,
        "cache_by_provider": true,
        "conversation_history_threshold": 3,
        "vector_store_namespace": "BifrostCache"
      }
    }
  ],
  "governance": {
    "virtual_keys": [
      {
        "id": "vk-default",
        "name": "default",
        "is_active": true,
        "provider_configs": [
          {
            "id": 1,
            "provider": "opencode"
          },
          {
            "id": 2,
            "provider": "agnes"
          }
        ]
      }
    ]
  }
}
