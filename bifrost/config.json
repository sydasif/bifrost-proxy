{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "enable_logging": true,
    "compat": {
      "should_drop_params": true,
      "should_convert_params": true
    }
  },
  "providers": {
    "opencode": {
      "keys": [
        {
          "name": "opencode-key",
          "value": "env.OPENCODE_API_KEY",
          "models": ["mimo-v2.5-free"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://opencode.ai/zen",
        "default_request_timeout_in_seconds": 120,
        "max_retries": 1
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        }
      }
    },
    "nvidia": {
      "keys": [
        {
          "name": "nvidia-key-1",
          "value": "env.NVIDIA_API_KEY_1",
          "models": [
            "openai/gpt-oss-120b",
            "nvidia/nemotron-3-ultra-550b-a55b"
          ],
          "weight": 1.0
        },
        {
          "name": "nvidia-key-2",
          "value": "env.NVIDIA_API_KEY_2",
          "models": [
            "openai/gpt-oss-120b",
            "nvidia/nemotron-3-ultra-550b-a55b"
          ],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://integrate.api.nvidia.com",
        "default_request_timeout_in_seconds": 120,
        "max_retries": 1
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        }
      }
    },
    "agnes": {
      "keys": [
        {
          "name": "agnes-key",
          "value": "env.AGNES_API_KEY",
          "models": ["agnes-2.0-flash"],
          "weight": 1.0
        }
      ],
      "network_config": {
        "base_url": "https://apihub.agnes-ai.com",
        "default_request_timeout_in_seconds": 120,
        "max_retries": 1
      },
      "custom_provider_config": {
        "base_provider_type": "openai",
        "allowed_requests": {
          "chat_completion": true,
          "chat_completion_stream": true
        }
      }
    }
  },
  "vector_store": {
    "enabled": true,
    "type": "redis",
    "config": {
      "addr": "redis:6379"
    }
  },
  "plugins": [
    {
      "enabled": true,
      "name": "semantic_cache",
      "config": {
        "dimension": 1,
        "ttl": "10m",
        "cache_by_model": true,
        "cache_by_provider": true,
        "conversation_history_threshold": 3,
        "vector_store_namespace": "BifrostCache"
      }
    }
  ],
  "governance": {
    "virtual_keys": [
      {
        "id": "vk-default",
        "name": "default",
        "is_active": true,
        "provider_configs": [
          {
            "id": 1,
            "provider": "opencode",
            "rate_limit": {
              "request_max_limit": 30,
              "request_reset_duration": "1m"
            }
          },
          {
            "id": 2,
            "provider": "nvidia",
            "allowed_models": [
              "openai/gpt-oss-120b",
              "nvidia/nemotron-3-ultra-550b-a55b"
            ],
            "rate_limit": {
              "request_max_limit": 30,
              "request_reset_duration": "1m"
            }
          },
          {
            "id": 3,
            "provider": "agnes",
            "rate_limit": {
              "request_max_limit": 30,
              "request_reset_duration": "1m"
            }
          }
        ]
      }
    ]
  }
}
